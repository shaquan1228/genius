#!/usr/bin/env bash
# bin/worktree-cleanup — remove stale temporal worktrees
#
# Usage:
#   bin/worktree-cleanup [--dry-run] [--age-days=7] [--yes] [--force]
#
# Removes worktrees older than N days (default 7)
# Preserves: main repo, branches with "keep-" prefix
# Interactive confirmation before removal

set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/lib/worktree-common.sh"

DRY_RUN=false
AGE_DAYS=7
YES=false
FORCE_YES=false

for arg in "$@"; do
  case $arg in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --age-days=*)
      AGE_DAYS="${arg#*=}"
      if [[ ! "$AGE_DAYS" =~ ^[0-9]+$ ]]; then
        echo "Error: --age-days must be a positive integer, got: '$AGE_DAYS'" >&2
        exit 1
      fi
      shift
      ;;
    --yes|-y)
      YES=true
      shift
      ;;
    --force)
      YES=true
      FORCE_YES=true
      shift
      ;;
    *)
      echo "Usage: bin/worktree-cleanup [--dry-run] [--age-days=7] [--yes] [--force]"
      exit 1
      ;;
  esac
done

if [[ ! -d "$WORKTREE_BASE" ]]; then
  echo "No worktree directory found at: $WORKTREE_BASE"
  exit 0
fi

echo "Scanning for temporal worktrees older than $AGE_DAYS days..."
echo ""

WORKTREES_TO_REMOVE=()
CUTOFF_DATE=$(date -v-"${AGE_DAYS}"d '+%s' 2>/dev/null || date -d "$AGE_DAYS days ago" '+%s')

while IFS= read -r line; do
  WORKTREE_PATH=$(echo "$line" | awk '{print $1}')
  BRANCH=$(echo "$line" | awk '{print $3}' | sed 's/\[//' | sed 's/\]//')
  
  if [[ "$WORKTREE_PATH" == "$REPO_ROOT" ]]; then
    continue
  fi
  
  if [[ "$BRANCH" == "keep-"* ]]; then
    continue
  fi
  
  if [[ ! "$BRANCH" =~ ^(agent-|temp-) ]]; then
    continue
  fi
  
  if [[ ! -d "$WORKTREE_PATH" ]]; then
    continue
  fi
  
  WORKTREE_AGE=$(stat -f %m "$WORKTREE_PATH" 2>/dev/null || stat -c %Y "$WORKTREE_PATH")
  
  if [[ $WORKTREE_AGE -lt $CUTOFF_DATE ]]; then
    WORKTREES_TO_REMOVE+=("$WORKTREE_PATH|$BRANCH")
  fi
done < <(git worktree list)

if [[ ${#WORKTREES_TO_REMOVE[@]} -eq 0 ]]; then
  echo "No stale temporal worktrees found."
  wt_log "CLEANUP: No stale worktrees found (age threshold: $AGE_DAYS days)"
  exit 0
fi

echo "Found ${#WORKTREES_TO_REMOVE[@]} stale temporal worktree(s):"
echo ""

for entry in "${WORKTREES_TO_REMOVE[@]}"; do
  WORKTREE_PATH="${entry%|*}"
  BRANCH="${entry#*|}"
  AGE_DAYS_ACTUAL=$(( ($(date '+%s') - $(stat -f %m "$WORKTREE_PATH" 2>/dev/null || stat -c %Y "$WORKTREE_PATH")) / 86400 ))
  echo "  • $BRANCH"
  echo "    Path: $WORKTREE_PATH"
  echo "    Age: $AGE_DAYS_ACTUAL days"
  echo ""
done

if $DRY_RUN; then
  echo "[DRY RUN] Would remove ${#WORKTREES_TO_REMOVE[@]} worktree(s)"
  wt_log "CLEANUP DRY-RUN: Would remove ${#WORKTREES_TO_REMOVE[@]} worktrees"
  exit 0
fi

if ! $YES; then
  printf "Remove these worktrees? (y/N): "
  read -r CONFIRM
  if [[ ! "$CONFIRM" =~ ^[Yy]$ ]]; then
    echo "Cancelled"
    wt_log "CLEANUP: Cancelled by user"
    exit 0
  fi
fi

echo ""
echo "Removing worktrees..."

REMOVED_COUNT=0
for entry in "${WORKTREES_TO_REMOVE[@]}"; do
  WORKTREE_PATH="${entry%|*}"
  BRANCH="${entry#*|}"
  
  echo "  Removing: $BRANCH"
  
  if git worktree remove "$WORKTREE_PATH" 2>/dev/null; then
    echo "    ✓ Removed worktree"
    REMOVED_COUNT=$((REMOVED_COUNT + 1))
    wt_log "CLEANUP: Removed $BRANCH at $WORKTREE_PATH"
  else
    echo "    ✗ Failed to remove worktree (may have uncommitted changes)"
    wt_log "CLEANUP: Failed to remove $BRANCH at $WORKTREE_PATH"
    
    if $FORCE_YES; then
      FORCE_CONFIRM="y"
    else
      printf "    Force remove? (y/N): "
      read -r FORCE_CONFIRM
    fi
    
    if [[ "$FORCE_CONFIRM" =~ ^[Yy]$ ]]; then
      if git worktree remove --force "$WORKTREE_PATH" 2>/dev/null; then
        echo "    ✓ Force removed"
        REMOVED_COUNT=$((REMOVED_COUNT + 1))
        wt_log "CLEANUP: Force removed $BRANCH at $WORKTREE_PATH"
      else
        echo "    ✗ Force remove failed"
        wt_log "CLEANUP: Force remove failed for $BRANCH at $WORKTREE_PATH"
      fi
    fi
  fi
done

echo ""
echo "✓ Cleanup complete: removed $REMOVED_COUNT of ${#WORKTREES_TO_REMOVE[@]} worktree(s)"
log "CLEANUP: Completed - removed $REMOVED_COUNT worktrees"
