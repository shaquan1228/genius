#!/usr/bin/env bash
# bin/worktree — create or check out a git worktree
#
# Usage:
#   bin/worktree <branch-or-description>           # new branch from HEAD (or checkout if exists)
#   bin/worktree <branch-or-description> <base>    # new branch from <base>
#   bin/worktree --temporal <description>           # temporal worktree (temp- prefix, auto-cleanup)
#   bin/worktree --with-graphite <name>             # track with graphite after creation
#
# Smart naming:
#   Clean branch name (no spaces/special chars) → used as-is
#   Description (spaces/special chars)           → sanitized + timestamped
#
# Env vars:
#   GENIUS_WORKTREE_DIR   Override worktree base directory

set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/lib/worktree-common.sh"

usage() {
  echo "Usage:"
  echo "  bin/worktree <branch-or-description>           # create or checkout"
  echo "  bin/worktree <branch-or-description> <base>    # from specific base"
  echo "  bin/worktree --temporal <description>           # temp- prefix, auto-cleanup"
  echo "  bin/worktree --with-graphite <name>             # track with graphite"
  echo ""
  echo "Flags can be combined: bin/worktree --temporal --with-graphite \"implement auth\""
  exit 1
}

sanitize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//' | cut -c1-40
}

is_clean_branch_name() {
  [[ "$1" =~ ^[a-zA-Z0-9._/-]+$ ]]
}

# ── Parse flags ──────────────────────────────────────────────────────────────

TEMPORAL=false
WITH_GRAPHITE=false

while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --temporal)      TEMPORAL=true;     shift ;;
    --with-graphite) WITH_GRAPHITE=true; shift ;;
    --help|-h)       usage ;;
    *)               echo "Unknown flag: $1" >&2; usage ;;
  esac
done

INPUT="${1:?$(usage)}"
BASE="${2:-HEAD}"

# ── Resolve branch name ─────────────────────────────────────────────────────

if is_clean_branch_name "$INPUT"; then
  BRANCH="$INPUT"
else
  SANITIZED=$(sanitize "$INPUT")
  TIMESTAMP=$(date '+%Y%m%d-%H%M%S')
  BRANCH="${SANITIZED}-${TIMESTAMP}"
fi

if $TEMPORAL; then
  BRANCH="temp-${BRANCH}"
fi

WORKTREE_PATH="$WORKTREE_BASE/$BRANCH"

# ── Create worktree ─────────────────────────────────────────────────────────

mkdir -p "$WORKTREE_BASE"

if [[ -d "$WORKTREE_PATH" ]]; then
  echo "Worktree already exists at $WORKTREE_PATH"
  wt_log "SKIP: $BRANCH (already exists)"
  exit 0
fi

if git show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
  echo "Checking out existing branch '$BRANCH'..."
  git worktree add "$WORKTREE_PATH" "$BRANCH"
  wt_log "CHECKOUT: $BRANCH at $WORKTREE_PATH"
else
  echo "Creating new branch '$BRANCH' from $BASE..."
  git worktree add "$WORKTREE_PATH" -b "$BRANCH" "$BASE"
  wt_log "CREATE: $BRANCH from $BASE at $WORKTREE_PATH"
fi

# ── Graphite tracking ───────────────────────────────────────────────────────

if $WITH_GRAPHITE && command -v gt &>/dev/null; then
  PARENT_BRANCH=$(git rev-parse --abbrev-ref "$BASE")
  if [[ "$PARENT_BRANCH" == "HEAD" ]]; then
    PARENT_BRANCH=$(cd "$REPO_ROOT" && git branch --show-current)
  fi

  echo "  Tracking with graphite (parent: $PARENT_BRANCH)..."
  (cd "$WORKTREE_PATH" && gt track --parent "$PARENT_BRANCH" 2>/dev/null) \
    || echo "  Warning: Could not track with graphite"
fi

# ── Output ───────────────────────────────────────────────────────────────────

echo ""
echo "✓ Worktree ready: $WORKTREE_PATH"
echo ""
echo "  Open in Cursor:      cursor $WORKTREE_PATH"
echo "  Open in Claude Code: claude $WORKTREE_PATH"

if $TEMPORAL; then
  echo ""
  echo "  This is a TEMPORAL worktree (auto-cleanup eligible after 7 days)"
  echo "  To make permanent, rename branch to: keep-<name>"
fi
