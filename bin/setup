#!/usr/bin/env bash
# bin/setup — inject genius identity into Claude Code and Cursor.
#
# Writes:
#   ~/.claude/CLAUDE.md          auto-loaded by Claude Code globally
#   .cursor/rules/genius.mdc    auto-loaded by Cursor in this repo
#
# Safe to re-run (idempotent).

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

for arg in "$@"; do
  case $arg in
    --help|-h)
      echo "Usage: bin/setup"
      echo "Injects genius identity into Claude Code and Cursor."
      exit 0
      ;;
    *)
      echo "Unknown argument: $arg" >&2
      exit 1
      ;;
  esac
done

mkdir -p "$HOME/.claude"
printf '# Engineering context (genius)\n\n@%s/docs/identity.md\n' "$ROOT_DIR" > "$HOME/.claude/CLAUDE.md"
echo "✓ Wrote ~/.claude/CLAUDE.md"

CURSOR_MDC="$ROOT_DIR/.cursor/rules/genius.mdc"
mkdir -p "$(dirname "$CURSOR_MDC")"
printf -- '---\nalwaysApply: true\ndescription: Engineering identity and operating principles\n---\n\n@%s/docs/identity.md\n' "$ROOT_DIR" > "$CURSOR_MDC"
echo "✓ Wrote .cursor/rules/genius.mdc"

echo ""
echo "Done. Open a new Claude Code or Cursor session — genius identity is now active."
echo ""
echo "For global Cursor coverage, paste into Cursor > Settings > Rules for AI:"
echo "  @${ROOT_DIR}/docs/identity.md"
