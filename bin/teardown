#!/usr/bin/env bash
# bin/teardown — remove genius identity injection.
#
# Usage: bin/teardown [--confirm]
# Dry-run by default. Pass --confirm to execute.
#
# Removes the # BEGIN GENIUS ... # END GENIUS block from ~/.claude/CLAUDE.md
# and removes .cursor/rules/genius.mdc. Leaves all other CLAUDE.md content intact.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
CURSOR_MDC="$ROOT_DIR/.cursor/rules/genius.mdc"
BEGIN_MARKER="# BEGIN GENIUS"
CONFIRM=false

for arg in "$@"; do
  case $arg in
    --confirm) CONFIRM=true ;;
    --help|-h)
      echo "Usage: bin/teardown [--confirm]"
      echo "Removes genius identity injection. Dry-run by default."
      exit 0
      ;;
    *) echo "Unknown argument: $arg" >&2; exit 1 ;;
  esac
done

HAS_BLOCK=false
grep -q "^$BEGIN_MARKER" "$CLAUDE_MD" 2>/dev/null && HAS_BLOCK=true

echo "Will remove:"
$HAS_BLOCK && echo "  genius block from ~/.claude/CLAUDE.md" || echo "  genius block (not found in ~/.claude/CLAUDE.md — skip)"
[ -f "$CURSOR_MDC" ] && echo "  .cursor/rules/genius.mdc" || echo "  .cursor/rules/genius.mdc (not found — skip)"

if ! $CONFIRM; then
  echo ""; echo "Dry run. Pass --confirm to execute."; exit 0
fi

if $HAS_BLOCK; then
  awk '/^# BEGIN GENIUS/{in_block=1; next} /^# END GENIUS/{in_block=0; next} !in_block{print}' \
    "$CLAUDE_MD" > "$CLAUDE_MD.tmp" && mv "$CLAUDE_MD.tmp" "$CLAUDE_MD"
  echo "✓ Removed genius block from ~/.claude/CLAUDE.md"
fi

if [ -f "$CURSOR_MDC" ]; then
  rm "$CURSOR_MDC" && echo "✓ Removed .cursor/rules/genius.mdc"
fi

echo ""; echo "Done. Restart Claude Code or Cursor to clear injected context."
