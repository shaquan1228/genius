#!/usr/bin/env bash
# bin/teardown — remove genius identity injection.
#
# Usage: bin/teardown [--confirm]
# Dry-run by default. Pass --confirm to execute.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIRM=false

for arg in "$@"; do
  case $arg in
    --confirm) CONFIRM=true ;;
    --help|-h)
      echo "Usage: bin/teardown [--confirm]"
      echo "Removes genius identity injection. Dry-run by default."
      exit 0
      ;;
    *) echo "Unknown argument: $arg" >&2; exit 1 ;;
  esac
done

CLAUDE_MD="$HOME/.claude/CLAUDE.md"
CURSOR_MDC="$ROOT_DIR/.cursor/rules/genius.mdc"

echo "Will remove:"
if [ -f "$CLAUDE_MD" ] && grep -q "$ROOT_DIR" "$CLAUDE_MD"; then
  echo "  ~/.claude/CLAUDE.md"
else
  echo "  ~/.claude/CLAUDE.md (not pointing to this repo — skip)"
fi
[ -f "$CURSOR_MDC" ] && echo "  .cursor/rules/genius.mdc" || echo "  .cursor/rules/genius.mdc (not found — skip)"

if ! $CONFIRM; then
  echo ""; echo "Dry run. Pass --confirm to execute."; exit 0
fi

if [ -f "$CLAUDE_MD" ] && grep -q "$ROOT_DIR" "$CLAUDE_MD"; then
  rm "$CLAUDE_MD" && echo "✓ Removed ~/.claude/CLAUDE.md"
fi
if [ -f "$CURSOR_MDC" ]; then
  rm "$CURSOR_MDC" && echo "✓ Removed .cursor/rules/genius.mdc"
fi

echo ""; echo "Done. Restart Claude Code or Cursor to clear injected context."
