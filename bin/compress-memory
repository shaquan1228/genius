#!/usr/bin/env bash
# compress-memory: Semantically compress Claude memory/prompt files using claude -p
# Usage:
#   compress-memory <file>           # compress a single file
#   compress-memory --all            # compress all quanbot + memory files
#   compress-memory --dry-run <file> # preview savings without writing

set -euo pipefail

QUANBOT_DIR="${QUANBOT_DIR:-$HOME/Desktop/quanbot}"
MEMORY_DIR="${MEMORY_DIR:-$HOME/.claude/projects/-Users-shaquan1228-Desktop-omar/memory}"

DRY_RUN=false
ALL=false
FILES=()

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --all)     ALL=true ;;
    *)         FILES+=("$arg") ;;
  esac
done

if $ALL; then
  FILES=(
    "$QUANBOT_DIR/identity.md"
    "$QUANBOT_DIR/rules.md"
    "$QUANBOT_DIR/workflow.md"
    "$QUANBOT_DIR/prompts/stack.md"
    "$QUANBOT_DIR/prompts/implementer.md"
    "$QUANBOT_DIR/prompts/planner.md"
    "$QUANBOT_DIR/prompts/reviewer.md"
  )
  # Add auto-memory files if they exist
  if [ -d "$MEMORY_DIR" ]; then
    while IFS= read -r f; do FILES+=("$f"); done < <(find "$MEMORY_DIR" -name "*.md" 2>/dev/null)
  fi
fi

if [ ${#FILES[@]} -eq 0 ]; then
  echo "Usage: compress-memory [--dry-run] [--all] <file...>" >&2
  exit 1
fi

TOTAL_SAVED=0

compress_file() {
  local file="$1"

  if [ ! -f "$file" ]; then
    echo "skip: $file (not found)" >&2
    return
  fi

  local original_chars
  original_chars=$(wc -c < "$file")

  # Rough token estimate: ~3.5 chars/token for English prose
  local original_tokens=$(( original_chars * 2 / 7 ))

  local compressed
  compressed=$(claude -p "$(cat <<'PROMPT'
Rewrite this file to use the minimum tokens possible while preserving ALL information,
intent, and technical specifics. Rules:
- Keep frontmatter (--- ... ---) blocks exactly as-is
- Condense verbose prose to dense, imperative phrasing
- Remove examples that duplicate the rule they illustrate
- Merge redundant points
- Keep all specific facts: names, commands, URLs, file paths
- Output ONLY the rewritten content, no commentary
PROMPT
)" --no-markdown < "$file" 2>/dev/null) || {
    echo "FAILED: $file" >&2
    return 1
  }

  if [ -z "$compressed" ]; then
    echo "SKIPPED: $file (empty output)" >&2
    return
  fi

  local compressed_chars=${#compressed}
  local compressed_tokens=$(( compressed_chars * 2 / 7 ))
  local saved=$(( original_tokens - compressed_tokens ))
  local pct=0
  [ "$original_tokens" -gt 0 ] && pct=$(( saved * 100 / original_tokens ))

  if $DRY_RUN; then
    echo "dry-run: $file — ${original_tokens}→${compressed_tokens} tokens (-${pct}%)"
    return
  fi

  cp "$file" "${file}.bak"
  printf '%s\n' "$compressed" > "$file"
  echo "✓ $file — ${original_tokens}→${compressed_tokens} tokens (-${pct}%, backup: ${file}.bak)"
  TOTAL_SAVED=$(( TOTAL_SAVED + saved ))
}

for f in "${FILES[@]}"; do
  compress_file "$f"
done

if ! $DRY_RUN && [ "$TOTAL_SAVED" -gt 0 ]; then
  echo ""
  echo "Total saved: ~${TOTAL_SAVED} tokens"
fi
