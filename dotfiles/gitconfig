[user]
	name = Shaquan Nelson
	# email is intentionally omitted — set per-machine:
	#   git config --global user.email "you@example.com"

[core]
	editor = vim
	autocrlf = input
	excludesfile = ~/.gitignore_global

[pull]
	rebase = true

[rebase]
	autosquash = true

[push]
	default = current
	autoSetupRemote = true

[alias]
	lg = log --oneline --graph --decorate --all
	st = status -sb
	co = checkout
[color]
	ui = auto

[color "status"]
	branch    = bright cyan bold
	added     = bright green
	changed   = bright yellow
	untracked = bright blue
	deleted   = bright red

[color "branch"]
	current = bright cyan bold
	local   = cyan
	remote  = bright blue

[color "diff"]
	meta      = yellow bold
	frag      = magenta bold
	old       = bright red
	new       = bright green
	whitespace = red reverse

[color "decorate"]
	branch       = bright cyan bold
	remoteBranch = bright blue
	tag          = bright yellow bold
	stash        = magenta
	HEAD         = white bold

[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
