[user]
	name = Shaquan Nelson
	# email is intentionally omitted — set per-machine:
	#   git config --global user.email "you@example.com"

[core]
	editor = vim
	autocrlf = input
	excludesfile = ~/.gitignore_global

[pull]
	rebase = true

[rebase]
	autosquash = true

[push]
	default = current
	autoSetupRemote = true

[alias]
	lg = log --oneline --graph --decorate --all
	st = status -sb
	co = checkout
[color]
	ui = auto

[color "status"]
	branch    = brightcyan bold
	added     = brightgreen
	changed   = brightyellow
	untracked = brightblue
	deleted   = brightred

[color "branch"]
	current = brightcyan bold
	local   = cyan
	remote  = brightblue

[color "diff"]
	meta      = yellow bold
	frag      = magenta bold
	old       = brightred
	new       = brightgreen
	whitespace = red reverse

[color "decorate"]
	branch       = brightcyan bold
	remoteBranch = brightblue
	tag          = brightyellow bold
	stash        = magenta
	HEAD         = white bold

[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
